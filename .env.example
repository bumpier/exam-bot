# Copy this file to .env and fill in the values.

# Ollama base URL (default is localhost; change if running Ollama on a remote host)
OLLAMA_BASE_URL=http://localhost:11434

# LLM provider: ollama or openai
LLM_PROVIDER=openai

# Ollama model to use for MCQ generation
# Run `ollama list` to see available models, or `ollama pull llama3.2` to download
OLLAMA_MODEL=llama3.2

# Hard generation limits for low-latency responses
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=220
# Comma-separated stop sequences
OLLAMA_STOP=```

# OpenAI / ChatGPT settings (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
# Cost-effective default for question generation
OPENAI_MODEL=gpt-4o-mini
# Keep outputs compact for lower latency
OPENAI_MAX_TOKENS=700
# End slow requests quickly and retry/fallback
OPENAI_TIMEOUT_SECONDS=25

# App login (required to access the UI)
APP_LOGIN_USERNAME=admin
APP_LOGIN_PASSWORD=change-me

# Path to the persistent ChromaDB directory (relative to project root)
CHROMA_DB_PATH=./chroma_db

# ChromaDB collection name
# Use a new name if you change embedding models to avoid embedding-function conflicts.
CHROMA_COLLECTION=compliance_books_ollama

# Embedding model
# Recommended (fully local, no Hugging Face downloads):
#   - ollama:nomic-embed-text   (run: ollama pull nomic-embed-text)
EMBEDDING_MODEL=ollama:nomic-embed-text

# Number of context chunks to retrieve per question
RETRIEVAL_TOP_K=3
